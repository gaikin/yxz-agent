{
  "name": "yxz-agent",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build:subprocess": "tsc -p tsconfig.json",
    "build:webapp": "vite build --config webapp/vite.config.ts",
    "build": "npm run clean && npm run build:subprocess && npm run build:webapp",
    "dev:webapp": "vite --config webapp/vite.config.ts",
    "test": "npm run build:subprocess && node --test dist/tests/*.test.js",
    "demo:mcp": "node scripts/demo-mcp-tool.js",
    "demo:skill": "npm run build && node scripts/run-local-skill.js",
    "demo:schedule": "node scripts/demo-local-schedule.js",
    "mock:mcp": "node subprocess/schedule/mock-mcp-server.js"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.2",
    "vite": "^7.1.7",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "antd": "^5.27.2",
    "axios": "^1.15.0",
    "cron-parser": "^5.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.9.4",
    "styled-components": "^6.1.18",
    "zustand": "^5.0.8"
  },
  "peerDependencies": {
    "react": ">=18"
  }
}
