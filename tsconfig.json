{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "experimentalDecorators": true,
    "rootDir": ".",
    "outDir": "dist",
    "types": ["node"]
  },
  "include": [
    "share/**/*.ts",
    "types/**/*.ts",
    "subprocess/service/**/*.ts",
    "webapp/src/**/*.ts",
    "webapp/src/**/*.tsx",
    "tests/**/*.ts"
  ]
}
